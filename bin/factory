#!/usr/bin/env raku

use v6.d;
BEGIN %*ENV<ORM_LOG_FILE> //= 'log/error.log' if 'log'.IO.d;

sub MAIN(*@args) {
  my $migrate-dir = 'db/migrate'.IO;
  unless $migrate-dir.d && $migrate-dir.dir.grep({ .extension eq 'raku' }) {
    exit 0;
  }

  my $available = try { require ::('ORM::ActiveRecord::Schema::Migrate'); True };
  unless $available {
    note "bin/factory: ORM::ActiveRecord::Schema::Migrate is required to run migrations but is not available.";
    note "  install it with: zef install ORM::ActiveRecord";
    exit 1;
  }

  require ::('ORM::ActiveRecord::Schema::Migrate') <Migrate>;
  my $migrate-class = ::('Migrate');
  $migrate-class.new(:@args).run;
}
